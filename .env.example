# Figma Personal Access Token (scope: File content -> read).
# Create at https://www.figma.com/developers/api#access-tokens
# The figma2web tools read FIGMA_SECRET_KEY (or FIGMA_TOKEN) from this file.
# Copy to .env and fill in. .env is gitignored — never commit the real token.
FIGMA_SECRET_KEY=figd_your_token_here

# Target site/frame: the skill and tools ALWAYS use this as the default target,
# so you never pass a URL on the command line (use --node only to pick a frame).
FIGMA_FILE_URL=https://www.figma.com/design/<fileKey>/<name>?node-id=<id>
